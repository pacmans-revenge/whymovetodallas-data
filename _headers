# Cloudflare Pages HTTP Headers — whymovetodallas.com
# Last updated: May 2026
#
# Applies to every route on the site.
# Static assets (CSS, images) get long-lived cache headers.
# HTML pages get short cache so deploys propagate quickly.

# ── Security headers on all routes ───────────────────────────────────────────
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; frame-src https://www.youtube.com https://www.youtube-nocookie.com https://www.openstreetmap.org; connect-src 'self' https://raw.githubusercontent.com https://www.google-analytics.com https://region1.google-analytics.com https://whymovetodallas-app.vercel.app; object-src 'none'; base-uri 'self'; form-action 'self' https://whymovetodallas.com;

# ── HTML pages — short cache so deploys go live immediately ──────────────────
/*.html
  Cache-Control: public, max-age=300, s-maxage=86400

# ── CSS — long-lived immutable cache (filenames change on update) ─────────────
/css/*
  Cache-Control: public, max-age=31536000, immutable

# ── Images — long-lived immutable cache ──────────────────────────────────────
/images/*
  Cache-Control: public, max-age=31536000, immutable

# ── Fonts (if self-hosted in future) ─────────────────────────────────────────
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# ── Suburb profiles JSON — allow cross-origin reads (Squarespace pages fetch this) ──
/suburb-profiles.json
  Cache-Control: public, max-age=3600, s-maxage=86400
  Access-Control-Allow-Origin: *

# ── PDF assets — force download, no inline preview ───────────────────────────
/assets/*.pdf
  Content-Disposition: attachment
  Cache-Control: public, max-age=86400

# ── Robots + verification files — no cache needed ────────────────────────────
/robots.txt
  Cache-Control: public, max-age=86400
